// Copy this file to Secrets.xcconfig (same folder) and fill in real values.
// Secrets.xcconfig is gitignored and must never be committed.
//
// The app's Info.plist exposes these via build settings, e.g.
//   SUPABASE_URL = $(SUPABASE_URL)

// Apple Developer team id (Xcode, Settings, Accounts). Keeping it here means
// regenerating the project with xcodegen never loses the signing team.
DEVELOPMENT_TEAM = REPLACE_ME

// RevenueCat public SDK key for the iOS app (starts with appl_).
// From app.revenuecat.com, project LazyChef, App settings. Not needed until M4.
REVENUECAT_API_KEY = appl_REPLACE_ME

// Supabase project URL and anon key (safe for the client, still kept out of git).
SUPABASE_URL = https:/$()/REPLACE_ME.supabase.co
SUPABASE_ANON_KEY = REPLACE_ME
