{
  "expo": {
    "name": "FridgeSnap",
    "slug": "fridgesnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fridgesnap",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.usefridgesnap.app"
    },
    "android": {
      "package": "com.usefridgesnap.app",
      "adaptiveIcon": {
        "backgroundColor": "#74966A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FEF5EF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FridgeSnap uses your camera to identify the ingredients in your fridge."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FridgeSnap uses your photos to identify the ingredients in your fridge."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
